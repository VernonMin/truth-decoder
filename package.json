{
  "name": "truth-decoder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "npx @cloudflare/next-on-pages@1",
    "preview": "wrangler pages dev",
    "lint": "next lint",
    "db:migrate": "wrangler d1 execute truth-decoder-db --file=./schema.sql --remote",
    "db:migrate:local": "wrangler d1 execute truth-decoder-db --file=./schema.sql --local"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.577.0",
    "next": "^15.2.4",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.7",
    "@cloudflare/workers-types": "^4.20250317.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.2.4",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.8.3",
    "wrangler": "^3.114.4"
  }
}
